&lt;/span>&lt;span class="lnt">3
&lt;/span>&lt;span class="lnt">4
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-fallback" data-lang="fallback">&lt;span class="line">&lt;span class="cl">table title AS &amp;#34;标题&amp;#34;,date AS &amp;#34;创建时间&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">from &amp;#34;post&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">where draft=false
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">sort date desc
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
